# Python caches
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Runtime data
var/data/*
!var/data/.gitkeep
var/logs/*
!var/logs/.gitkeep
var/outputs/*
!var/outputs/.gitkeep
var/runtime/*
!var/runtime/.gitkeep
/logs/
/outputs/
/runtime/
/stats.db
/stats.db-wal
/stats.db-shm
/stats.db-*
*.db-wal
*.db-shm
*.db
*.sqlite
*.sqlite3
*.log

# Build artifacts and local packages
build/
dist/
*.egg-info/
*.spec
*.zip
tmp_wheels/

# Secrets and local env files
.env
.env.*
!.env.example
*.pem
*.key
id_rsa
id_ed25519

# Root-level user DOCX samples. Keep explicit test fixtures under tests/ only when reviewed.
/*.docx
~$*.docx

# IDE and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local tool/workspace metadata
.agents/
.codex/
.firecrawl/
.playwright-mcp/
.reasonix/
%USERPROFILE%/

# Nested standalone repository and nested Git metadata
**/.git/
