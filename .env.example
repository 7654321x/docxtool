# Server bind address
BIND_HOST=127.0.0.1
PORT=9527

# Python backend secrets. Use long random values in production.
# Example: python scripts/generate_secrets.py
ADMIN_TOKEN=change-me-admin-token
PROXY_SECRET=change-me-proxy-secret
# Set true in production. When omitted, HTTPS FRONTEND_ORIGIN defaults to secure cookies.
COOKIE_SECURE=
ADMIN_SESSION_TTL_SECONDS=43200

# Upload and DOCX safety limits.
DATABASE_PATH=var/data/stats.db
MAX_UPLOAD_SIZE_MB=10
MAX_DOCX_UNCOMPRESSED_MB=100
MAX_DOCX_FILE_COUNT=1000
MAX_DOCX_XML_SIZE_MB=20
MAX_DOCX_MEDIA_SIZE_MB=30
MAX_DOCX_COMPRESSION_RATIO=100
PROCESS_TIMEOUT_SECONDS=60
TASK_RETENTION_HOURS=24
MAX_CACHED_TASKS=500
CLEANUP_INTERVAL_MINUTES=30

# Trusted proxy configuration.
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_IPS=127.0.0.1,::1
# Optional in local development. Set to the exact Cloudflare Pages origin in production.
FRONTEND_ORIGIN=
PRODUCTION_MODE=false

# Cloudflare Pages environment variables:
# BACKEND_BASE_URL=http://43.133.167.18
# PROXY_SECRET=change-me-proxy-secret
